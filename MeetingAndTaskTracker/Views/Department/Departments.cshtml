@model IEnumerable<MeetingAndTaskTracker.Models.Department>

@{
    ViewData["Title"] = "Departments";
}

<h1>Departments</h1>
<br/>
<p>
    <a asp-action="AddDepartment" class="btn btn-primary">Add New Department</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td class="text-end">
                <a asp-action="EditDepartment" asp-route-id="@item.Id" class="btn btn-outline-primary">Edit</a>
                <a asp-action="DeleteDepartment" asp-route-id="@item.Id" class="btn btn-outline-primary">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>

<div>
    <a asp-controller="Account" asp-action="Dashboard" class="btn btn-outline-primary">Go to Dashboard</a>
</div>
