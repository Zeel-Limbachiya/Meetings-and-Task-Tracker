@model IEnumerable<MeetingAndTaskTracker.Models.Employee>

@{
    ViewData["Title"] = "Employees";
}

<h1>Employees</h1>

<p>
    <a asp-action="AddEmployee" class="btn btn-primary">Add Employee</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Email)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Mobile)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Department)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Email)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Mobile)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Department.Name)
            </td>
            <td class="text-end">
                <a asp-action="EditEmployee" asp-route-id="@item.Id" class="btn btn-outline-primary">Edit</a> |
                <a asp-action="EmployeeDetails" asp-route-id="@item.Id" class="btn btn-outline-primary">Details</a> |
                <a asp-action="DeleteEmployee" asp-route-id="@item.Id" class="btn btn-outline-primary">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>


<div>
    <a asp-controller="Account" asp-action="Dashboard" class="btn btn-outline-primary">Go to Dashboard</a>
</div>